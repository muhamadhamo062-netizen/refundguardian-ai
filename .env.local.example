# Local dev: app runs on port 3000 only (`npm run dev`). Keep this so links/emails match.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (required for auth and API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — required for a clean dashboard “system check”, saving Gmail IMAP creds reliably, and IMAP/cron routes:
# - GET /api/health (detects missing tables via service role)
# - POST /api/user/gmail-imap (uses service role when set — bypasses RLS/session quirks)
# - POST /api/imap/scan-now, GET/POST /api/cron/imap-scan
# Paste from Supabase → Project Settings → API → service_role (never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=

# For instant post-signup dashboard: Supabase → Authentication → Providers → Email → disable "Confirm email"
# (or the app falls back to Sign in with the same credentials).
# Auth passwords: Supabase enforces a minimum length (usually 6). The app does not add extra rules.

# Paddle Billing (no Stripe) — required for subscriptions and customer portal
# Client token: Paddle → Developer tools → Authentication → Client-side tokens
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# Server API key: same area → API keys (sandbox vs production must match NEXT_PUBLIC_PADDLE_ENV)
# PADDLE_API_KEY=
# sandbox | production
# NEXT_PUBLIC_PADDLE_ENV=sandbox

# OpenAI — one API key enables the Refyndra AI Lawyer (disputes, advisory scan, IMAP letters, receipt JSON).
# If unset, the app stays in manual-template mode (human-written only in the UI).
# OPENAI_API_KEY=
# Optional model override (default: gpt-4o for executive-quality U.S. English)
# OPENAI_MODEL=gpt-4o

# Optional: POST /api/compensation-letter forwards JSON to this URL (your OpenAI proxy, n8n, etc.)
# Must be https. Not legal advice; does not guarantee merchant payment.
# COMPENSATION_LETTER_WEBHOOK_URL=https://your-automation.example.com/rg-letter
# Optional shared secret header X-Refyndra-Secret for your webhook
# COMPENSATION_LETTER_WEBHOOK_SECRET=

# Production: override the URL above, e.g. NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Instant Golden Email: Supabase → Database Webhooks → POST /api/webhooks/refund-notification
# (fires when `notifications` row is inserted for refund_success_upgrade). Same secret in header
# `x-refyndra-webhook-secret` or `Authorization: Bearer ...`
# REFUND_NOTIFICATION_WEBHOOK_SECRET=

# Resend — refund success emails (webhook above + cron backup: /api/cron/refund-notification-emails)
# RESEND_API_KEY=re_...
# From must be a verified sender/domain in Resend (use onboarding@resend.dev only for testing).
# RESEND_FROM_EMAIL=onboarding@resend.dev
# Display prices in refund emails / modal (optional — Golden Email uses $9 positioning)
# NEXT_PUBLIC_PRO_MONTHLY_DISPLAY=$9/month
# NEXT_PUBLIC_PRO_ANNUAL_DISPLAY=$89/year
# Optional override for the “$40+ more waiting” marketing line in success emails
# NEXT_PUBLIC_UPGRADE_TEASER_LINE=But we found $40+ more waiting in your history! Upgrade to Pro for just $9 to unlock your full AI Lawyer and claim every cent you are owed.

# Optional: set to 1 for verbose /api/orders server logs (including post-ingest automation warnings). Default: quiet.
# ORDERS_API_DEBUG=1
#
# Database: apply all supabase/migrations your deployment needs (orders, IMAP credentials, etc.).
#
# Mobile Gmail (App Password) — Fernet key; server encrypts before DB (migrations 015 + 017).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GMAIL_IMAP_ENCRYPTION_KEY=

# Shared secret for GET/POST /api/cron/imap-scan (header x-cron-secret or Authorization: Bearer).
# Set the same value in Vercel → Environment Variables for scheduled IMAP runs.
CRON_SECRET=


# Paddle — catalog price IDs (overlay checkout)
# PADDLE_PRICE_MONTHLY=pri_...
# PADDLE_PRICE_ANNUAL=pri_...
# Optional: Seller / Vendor ID (reference)
# NEXT_PUBLIC_PADDLE_VENDOR_ID=
# Notification destination secret → /api/billing/webhook
# PADDLE_NOTIFICATION_WEBHOOK_SECRET=

# Support email (server-only, hidden from clients)
# Uses 3Forms to forward Support form submissions to your inbox.
# Create a 3Forms form → set your recipient email there → paste access key here.
# THREEFORMS_ACCESS_KEY=
