# Supabase (required for auth and API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: service role (server-only). Improves GET /api/health DB detection (bypasses RLS).
# SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — advisory refund decisions (server-only)
# OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: POST /api/compensation-letter forwards JSON to this URL (your OpenAI proxy, n8n, etc.)
# Must be https. Not legal advice; does not guarantee merchant payment.
# COMPENSATION_LETTER_WEBHOOK_URL=https://your-automation.example.com/rg-letter
# Optional shared secret header X-RefundGuardian-Secret for your webhook
# COMPENSATION_LETTER_WEBHOOK_SECRET=

# Optional: production site URL for server-side redirects
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Optional: set to 1 to print server logs for GET/POST /api/orders (default: quiet)
# ORDERS_API_DEBUG=1
#
# Database: apply all supabase/migrations including 014_extension_sync_events.sql
# so POST /api/sync-extension can persist extension batch notifications.
#
# Mobile Gmail (App Password) — server encrypts before DB (migration 015_imap_app_credentials.sql)
# GMAIL_IMAP_ENCRYPTION_KEY=
#
# Cron: GET/POST /api/cron/imap-scan (requires header x-cron-secret or Authorization: Bearer)
# Vercel Cron sends this automatically when CRON_SECRET is set in project env.
# CRON_SECRET=


# Optional: Chrome Web Store URL for the “Install RefundGuardian AI” dashboard button
# NEXT_PUBLIC_CHROME_WEB_STORE_URL=https://chromewebstore.google.com/detail/your-extension-id

# Stripe (subscription billing — no charges without Checkout + user consent)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_MONTHLY=price_...
# STRIPE_PRICE_ANNUAL=price_...

# Support email (server-only, hidden from clients)
# Uses 3Forms to forward Support form submissions to your inbox.
# Create a 3Forms form → set your recipient email there → paste access key here.
# THREEFORMS_ACCESS_KEY=
